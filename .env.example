# ── Runtime note ─────────────────────────────────────────────────────────────
# When running on Google Colab this file has no effect.
# KNIGHT reads os.environ, and all variables below are set explicitly by the
# notebook's "Load secrets" cell before any KNIGHT module is imported.
# This file is kept in sync with the notebook for documentation purposes only.
# ─────────────────────────────────────────────────────────────────────────────

# llama-cpp-python[server] on Colab — started as subprocess on port 8081
#   python -m llama_cpp.server \
#       --model /path/to/gemma-3-4b-it-qat-q4_0.gguf \
#       --port 8081 --chat_format gemma
OPENAI_API_BASE=http://localhost:8081/v1
OPENAI_MODEL=gemma-3-4b-it-qat-q4_0
OPENAI_API_KEY=dummy

# Neo4j AuraDB — on Colab, NEO4J_URI/USER/PASSWORD are read from Colab Secrets
# and mapped to GPT_NEO4J_* by the notebook. REBEL agent is not used.
GPT_NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
GPT_NEO4J_USER=<username>
GPT_NEO4J_PASSWORD=<password>
