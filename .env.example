# Required: OpenAI-compatible API key (used by default LLM)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# Optional: override API base URL for non-OpenAI endpoints
# OPENAI_API_BASE=https://api.openai.com/v1

# Neo4j for GPT agent (required if using GPT agent)
GPT_NEO4J_URI=bolt://localhost:7687
GPT_NEO4J_USER=neo4j
GPT_NEO4J_PASSWORD=your-neo4j-password

# Neo4j for REBEL agent (can match GPT; required if using REBEL agent)
REBEL_NEO4J_URI=bolt://localhost:7687
REBEL_NEO4J_USER=neo4j
REBEL_NEO4J_PASSWORD=your-neo4j-password

# Optional: max recursion depth for triplet extraction (default: 2)
# MAX_DEPTH=2
